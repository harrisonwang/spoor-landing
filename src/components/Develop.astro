---
import type { Lang } from '../i18n/ui';
import { useT } from '../i18n/ui';
import CodeTabs from './CodeTabs.astro';
import { devTabs } from '../data/terminals';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useT(lang);
---
<section id="develop">
  <div class="wrap grid">
    <div class="col">
      <div class="eyebrow">{t('develop.eyebrow')}</div>
      <h2>{t('develop.title.a')}{t('develop.title.b') && <span> {t('develop.title.b')}</span>}</h2>
      <p class="sub">{t('develop.sub')}</p>
      <a class="link" href="https://github.com/harrisonwang/spoor/tree/main/examples" target="_blank" rel="noopener">{t('develop.link')}<span>→</span></a>
    </div>
    <CodeTabs tabs={devTabs} group="develop" />
  </div>
</section>

<style>
  #develop { background: var(--paper); }
  .grid { padding: 88px 28px; display: grid; grid-template-columns: 1fr 1.1fr; gap: 48px; align-items: center; }
  h2 { font-weight: 700; font-size: clamp(28px, 2.8vw, 38px); line-height: 1.12; margin: 13px 0 0; max-width: 680px; text-wrap: balance; }
  .sub { font-size: 16px; line-height: 1.65; color: var(--ink-2); margin: 18px 0 0; max-width: 520px; }
  .link { display: inline-flex; align-items: center; gap: 7px; font-size: 14px; font-weight: 600; color: var(--ink); border-bottom: 2px solid #e7c9b8; padding-bottom: 2px; margin-top: 22px; transition: border-color .15s; }
  .link:hover { border-color: var(--terracotta); }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
</style>
