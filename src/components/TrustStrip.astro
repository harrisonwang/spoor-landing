---
import type { Lang } from '../i18n/ui';
import { useT } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useT(lang);
const fmts = ['PDF', 'DOCX', 'XLSX', 'PPTX', 'URL', 'EPUB', 'IPYNB', 'CSV / TSV'];
---
<div class="strip">
  <div class="wrap row">
    <span class="lead">{t('trust.lead')}</span>
    {fmts.map((f, i) => (
      <>
        {i > 0 && <span class="sep">·</span>}
        <span>{f}</span>
      </>
    ))}
  </div>
</div>
<style>
  .strip { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--paper-2); }
  .row { padding: 18px 28px; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 14px 32px; font-family: var(--mono); font-size: 12.5px; color: var(--muted); }
  .lead { color: var(--terracotta-dark); font-weight: 600; letter-spacing: .04em; }
  .sep { opacity: .4; }
</style>
