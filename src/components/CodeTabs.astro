---
// Static tabbed code block (no animation). Used by Install & Develop.
// Tab switching is plain DOM via .is-on class — robust and framework-free.
import type { Line } from '../data/terminals';
interface Props { tabs: { label: string; lines: Line[] }[]; group: string; }
const { tabs, group } = Astro.props;
const COLOR: Record<string, string> = {
  norm: '#d8d4ca', accent: '#7fae6a', warn: '#e8915f', warnDim: '#9a8064',
  head: '#f4f0e6', dim: '#6f6a60', key: '#9db98a', uri: '#eaa074',
};
---
<div class="codebox">
  <div class="bar" data-group={group}>
    {tabs.map((tb, i) => (
      <button class:list={["tab-dark", { 'is-on': i === 0 }]} data-i={i}>{tb.label}</button>
    ))}
    <button class="copy" type="button" aria-label="Copy code" title="Copy code">&#8943;</button>
  </div>
  {tabs.map((tb, i) => (
    <pre class:list={["panel", { 'is-on': i === 0 }]} data-i={i}>{tb.lines.map((ln) => (
        <div style={`color:${COLOR[ln.kind] || '#d8d4ca'}`}>{ln.text || '\u00a0'}</div>
      ))}</pre>
  ))}
</div>

<script>
  document.querySelectorAll<HTMLElement>('.codebox').forEach((box) => {
    const btns = Array.from(box.querySelectorAll<HTMLButtonElement>('.bar button.tab-dark'));
    const copy = box.querySelector<HTMLButtonElement>('.copy');
    const panels = Array.from(box.querySelectorAll<HTMLElement>('.panel'));
    btns.forEach((b, i) => b.addEventListener('click', () => {
      btns.forEach((x, n) => x.classList.toggle('is-on', n === i));
      panels.forEach((p, n) => p.classList.toggle('is-on', n === i));
    }));
    copy?.addEventListener('click', async () => {
      const panel = panels.find((p) => p.classList.contains('is-on'));
      const text = panel?.innerText || '';
      if (!text) return;
      await navigator.clipboard?.writeText(text);
      const prev = copy.textContent;
      copy.textContent = '\u2713';
      setTimeout(() => { copy.textContent = prev; }, 1400);
    });
  });
</script>

<style>
  .codebox { background: var(--term-bg); border-radius: 15px; border: 1px solid var(--term-line); overflow: hidden; box-shadow: 0 30px 70px -30px rgba(50,28,14,.45); }
  .bar { display: flex; gap: 4px; padding: 11px 11px 0; background: var(--term-bg-2); border-bottom: 1px solid var(--term-line); flex-wrap: wrap; }
  .copy { margin-left: auto; align-self: flex-start; width: 30px; height: 30px; display: inline-flex; align-items: center; justify-content: center; border: none; background: #24211d; color: #8f887c; border-radius: 7px; cursor: pointer; font-size: 13px; transition: background .15s, color .15s; }
  .copy:hover { background: #302b25; color: #e8e2d6; }
  .panel { display: none; margin: 0; padding: 20px 22px; min-height: 260px; font-family: var(--mono); font-size: 13px; line-height: 1.66; white-space: pre-wrap; word-break: break-word; }
  .panel.is-on { display: block; }
</style>
