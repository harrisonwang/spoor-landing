---
import type { Lang } from '../i18n/ui';
import { useT } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useT(lang);
---
<footer>
  <div class="wrap top">
    <div class="left">
      <span class="dots"><i></i><i></i><i></i></span>
      <span class="name">spoor</span>
      <span class="tag">{t('footer.tagline')}</span>
    </div>
    <div class="ln">
      <a href="https://github.com/harrisonwang/spoor" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/harrisonwang/spoor/tree/main/examples" target="_blank" rel="noopener">Examples</a>
      <a href="https://github.com/harrisonwang/spoor/blob/main/LICENSE" target="_blank" rel="noopener">MIT</a>
    </div>
  </div>
  <div class="rule"><div class="wrap legal">© 2026 spoor.sh · MIT · {t('footer.legal')}</div></div>
</footer>

<style>
  footer { background: var(--term-bg); color: #9a9286; border-top: 1px solid var(--term-line); }
  .top { padding: 44px 28px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 22px; }
  .left { display: flex; align-items: center; gap: 11px; }
  .dots { display: inline-flex; align-items: center; gap: 3px; }
  .dots i { display: block; border-radius: 50%; }
  .dots i:nth-child(1) { width: 7px; height: 7px; background: #5a514a; }
  .dots i:nth-child(2) { width: 8px; height: 8px; background: #9a6a4d; }
  .dots i:nth-child(3) { width: 10px; height: 10px; background: var(--terracotta); }
  .name { font-family: var(--display); font-weight: 700; font-size: 18px; color: #faf6ec; }
  .tag { margin-left: 8px; font-size: 13px; }
  .ln { display: flex; gap: 26px; font-size: 13.5px; font-family: var(--mono); }
  .ln a:hover { color: #e8915f; }
  .rule { border-top: 1px solid var(--term-line); }
  .legal { padding: 16px 28px; font-size: 12px; color: #5f584f; font-family: var(--mono); }
</style>
