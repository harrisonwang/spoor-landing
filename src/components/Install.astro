---
import type { Lang } from '../i18n/ui';
import { useT } from '../i18n/ui';
import CodeTabs from './CodeTabs.astro';
import { installTabs } from '../data/terminals';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useT(lang);
---
<section id="install">
  <div class="wrap inner">
    <div class="lead">
      <div class="eyebrow">{t('install.eyebrow')}</div>
      <h2>{t('install.title')}</h2>
      <p class="sub">{t('install.sub')}</p>
    </div>
    <div class="box"><CodeTabs tabs={installTabs} group="install" /></div>
  </div>
</section>

<style>
  #install { background: var(--paper-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .inner { padding: 88px 28px; }
  .lead { text-align: center; max-width: 560px; margin: 0 auto 38px; }
  h2 { font-weight: 700; font-size: clamp(28px, 2.8vw, 38px); line-height: 1.12; margin: 12px 0 0; text-wrap: balance; }
  .sub { font-size: 16px; line-height: 1.65; color: var(--ink-2); margin: 16px auto 0; max-width: 520px; }
  .box { max-width: 680px; margin: 0 auto; }
  .box :global(.panel) { min-height: 184px; }
</style>
